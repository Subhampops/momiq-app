# ─────────────────────────────────────────────
# MomiQ – Environment Variables
# Copy this file to .env and fill in your keys
# ─────────────────────────────────────────────

# ── Google Gemini AI (AI Doctor Chat) ──────────
# Get your key at: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# ── OpenAI (Alternative AI fallback) ──────────
# Get your key at: https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=your_openai_api_key_here

# ── Spotify (Personalized Music) ───────────────
# Register at: https://developer.spotify.com/dashboard
VITE_SPOTIFY_CLIENT_ID=your_spotify_client_id_here
VITE_SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
# Spotify redirect URI (must be registered in Spotify dashboard)
VITE_SPOTIFY_REDIRECT_URI=http://localhost:3000/callback

# ── Civic Auth (Authentication) ────────────────
# Register at: https://auth.civic.com
VITE_CIVIC_CLIENT_ID=your_civic_client_id_here

# ── App Config ─────────────────────────────────
VITE_APP_NAME=MomiQ
VITE_APP_URL=http://localhost:3000
